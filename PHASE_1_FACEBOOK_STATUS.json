  ],
  "tokensEncrypted": true,
  "encryptionMethod": "AES-256-GCM",
  "longLivedTokenImplemented": true,
  "longLivedTokenDetails": {
    "userToken": "60 days (exchanged from short-lived)",
    "pageTokens": "Never expire (when obtained with long-lived user token)"
  },
  "refreshFlowImplemented": false,
